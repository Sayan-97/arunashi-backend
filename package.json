{
	"name": "arunashi-server",
	"version": "1.0.0",
	"description": "",
	"main": "dist/index.js",
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"splitting": false,
		"sourcemap": true,
		"clean": true,
		"format": [
			"esm"
		]
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsup",
		"start": "node dist/index.js",
		"check-types": "tsc --noEmit",
		"biome:lint": "biome lint --write",
		"biome:format": "biome format --write",
		"biome:check": "biome check --write",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@11.6.0",
	"type": "module",
	"dependencies": {
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.3",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*": "biome check --write"
	}
}
