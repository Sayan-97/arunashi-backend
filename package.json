{
	"name": "arunashi-server",
	"version": "1.0.0",
	"description": "",
	"main": "dist/index.js",
	"tsup": {
		"entry": [
			"src/index.ts"
		],
		"splitting": false,
		"sourcemap": true,
		"clean": true,
		"format": [
			"esm"
		]
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "prisma generate --schema=src/prisma/schema.prisma && tsup",
		"start": "node dist/index.js",
		"check-types": "tsc --noEmit",
		"biome:lint": "biome lint --write",
		"biome:format": "biome format --write",
		"biome:check": "biome check --write",
		"onboard:admin": "tsx src/scripts/onboard-admin.ts",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@11.6.0",
	"type": "module",
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"argon2": "^0.44.0",
		"compression": "^1.8.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"helmet": "^8.2.0",
		"jose": "^6.2.3",
		"morgan": "^1.11.0",
		"multer": "^2.2.0",
		"nodemailer": "^8.0.11",
		"pdf-to-png-converter": "^4.1.1",
		"pg": "^8.21.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/compression": "^1.8.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/morgan": "^1.9.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.9.3",
		"@types/nodemailer": "^8.0.1",
		"@types/pg": "^8.20.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prisma": "^7.8.0",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched"
	}
}
