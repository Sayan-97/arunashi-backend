generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  USER
}

model RegistrationRequest {
  id         String @id @default(uuid())
  name       String
  email      String @unique
  company    String
  phone      String
  address    String
  city       String?
  state      String?
  country    String?
  zipcode    String?
  pressTitle String @map("press_title")

  status RequestStatus @default(PENDING)

  activationToken ActivationToken?
  user            User?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("registration_requests")
}

model ActivationToken {
  id    String @id @default(uuid())
  token String @unique

  registrationRequestId String              @unique @map("registration_request_id")
  registrationRequest   RegistrationRequest @relation(fields: [registrationRequestId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("activation_tokens")
}

model User {
  id          String @id @default(uuid())
  name        String
  email       String @unique
  password    String
  company     String?
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String?
  zipcode     String?
  press_title String?

  role UserRole @default(USER)

  registrationRequestId String?             @unique @map("registration_request_id")
  registrationRequest   RegistrationRequest? @relation(fields: [registrationRequestId], references: [id])

  refreshTokens   RefreshToken[]
  savedLists      SavedList[]
  productRequests ProductRequest[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model SavedList {
  id        String   @id @default(uuid())
  name      String
  items     Json
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("saved_lists")
}

model ProductRequest {
  id        String        @id @default(uuid())
  items     Json
  status    RequestStatus @default(PENDING)
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("product_requests")
}

model ProductData {
  id            String   @id
  isActive      Boolean  @default(true) @map("is_active")
  linesheetLink String?  @map("linesheet_link")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("product_data")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Magazine {
  id          String   @id @default(uuid())
  link        String
  image       String?
  issueNumber String?  @map("issue_number")
  date        DateTime 
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("magazines")
}

model Diamond {
  id        String   @id @default(uuid())
  name      String
  link      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("diamonds")
}

model Gemstone {
  id        String   @id @default(uuid())
  name      String
  link      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("gemstones")
}

model Banner {
  id        String   @id @default(uuid())
  image     String
  link      String?
  isActive  Boolean  @default(true) @map("is_active")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  link      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model TermsAndConditions {
  id        String   @id @default(uuid())
  content   String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("terms_and_conditions")
}

model PrivacyPolicy {
  id        String   @id @default(uuid())
  content   String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("privacy_policy")
}

model AboutUs {
  id        String   @id @default(uuid())
  content   String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("about_us")
}
